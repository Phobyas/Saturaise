{%- liquid
  assign items_per_page = section.settings.items_per_page | default: 12
  assign items_per_row = 'span-4 auto sm-span-6'
  assign grid_items = 3
-%}

{% paginate blog.articles by items_per_page %}

<div
  class="section-blog-listing blog-listing-{{ section.id }} global__section"
  data-section-id="{{ section.id }}"
  data-section-type="blog-template"
  data-section-loaded="false"
  style="max-width: 1280px; margin: 0 auto;">

  <div class="grid__wrapper edge cg6 rg6">
    {% render 'article-loop',
      blog: blog,
      items_per_page: items_per_page,
      items_per_row: items_per_row,
      grid_items: grid_items
    %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="blog-pagination a-center pt8 pb8">
      {{ paginate | default_pagination: next: '→', previous: '←' }}
    </div>
  {% endif %}
</div>

{% endpaginate %}

{% style %}
  @media (min-width: 1920px) {
    .blog-listing-{{ section.id }} {
      max-width: 1600px !important;
    }
  }

  .blog-listing-{{ section.id }} .article-loop__excerpt {
    padding-top: 12px;
  }

  .blog-listing-{{ section.id }} .post-title {
    font-weight: 700;
  }

  .blog-listing-{{ section.id }} img {
    border-radius: 12px;
  }

  .blog-pagination .page {
    display: inline-block;
    padding: 8px 14px;
    margin: 0 2px;
    font-weight: 600;
  }

  .blog-pagination .page.current {
    text-decoration: underline;
  }
{% endstyle %}

{% schema %}
{
  "name": "Blog posts",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_featured_image",
      "label": "Show featured image",
      "default": true
    },
    {
      "type": "range",
      "id": "items_per_page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 12,
      "label": "Posts per page"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tags",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_comments",
      "label": "Show comment count",
      "default": true
    }
  ]
}
{% endschema %}