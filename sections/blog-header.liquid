{%- liquid
  assign heading = blog.title
  if section.settings.heading != blank
    assign heading = section.settings.heading
  endif
  assign subheading = section.settings.subheading
-%}

<div class="global__section section__banner-{{ section.id }} mt0"
  data-section-id="{{ section.id }}"
  data-section-type="blog-header"
  data-section-loaded="false"
  style="max-width: 1280px; margin: 0 auto;">

  <div class="grid__wrapper edge rg0 cg0">
    <div class="collection__page--description w-100 span-8 mt2 pb2 a-left">
      <div class="rte desc">
        <h1 class="text-2xl font-bold">{{ heading }}</h1>
        {%- if subheading != blank -%}
          <div class="blog-description mt1">
            {{ subheading }}
          </div>
        {%- endif -%}
        {%- if section.settings.show_post_count -%}
          <p class="blog-post-count text-sm text-text-200 mt1">
            {{ blog.articles_count }}
            {%- if blog.articles_count == 1 -%}
              post
            {%- else -%}
              posts
            {%- endif -%}
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- style -%}
    @media (min-width: 1920px) {
      .section__banner-{{ section.id }} {
        max-width: 1600px !important;
      }
    }

    .section__banner-{{ section.id }} .collection__page--description h1 {
      font-size: 32px;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 8px;
    }

    @media (max-width: 767px) {
      .section__banner-{{ section.id }} .collection__page--description h1 {
        font-size: 24px;
      }
    }

    .section__banner-{{ section.id }} .blog-description {
      color: var(--text-color-secondary, #666);
      font-size: 16px;
      line-height: 1.5;
    }

    .section__banner-{{ section.id }} .blog-post-count {
      color: var(--text-color-secondary, #666);
      font-size: 14px;
      font-weight: 500;
    }

    .section__banner-{{ section.id }} .collection__page--description {
      border-bottom: 1px solid #efefef;
      padding-bottom: 32px;
      margin-bottom: 0;
    }

    @media (max-width: 767px) {
      .section__banner-{{ section.id }} .collection__page--description {
        padding-bottom: 20px;
      }
    }
  {%- endstyle -%}
</div>

{% schema %}
{
  "name": "Blog header",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Custom heading",
      "info": "Leave blank to use blog title"
    },
    {
      "id": "subheading",
      "type": "richtext",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "show_post_count",
      "label": "Show post count",
      "default": true
    }
  ]
}
{% endschema %}